@using MudBlazor
@inherits LayoutComponentBase

<MudThemeProvider Theme="GetTheme()" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<div class="pulse-layout">
    <!-- Navigation Bar -->
    <MudAppBar Elevation="2" Color="Color.Primary" Class="pulse-navbar">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="width: 100%;">
            <MudIconButton Icon="@Icons.Material.Filled.Quiz" Color="Color.Inherit" Edge="Edge.Start" />
            <MudText Typo="Typo.h6" Style="font-weight: 700; color: white; flex-grow: 1;">
                Pulse Quiz
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Home" Color="Color.Inherit" href="/" />
        </MudStack>
    </MudAppBar>

    <!-- Main Content -->
    <div class="pulse-content" style="padding-top: 70px;">
        @Body
    </div>
</div>

<style>
    .pulse-layout {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
    }

    .pulse-navbar {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }

    .pulse-content {
        flex: 1;
        overflow-y: auto;
    }
</style>

@code {
    private MudTheme GetTheme() => new();
}
