@page "/instructor/qr/{SessionId}"
@using MudBlazor
@using Microsoft.AspNetCore.Components
@inject NavigationManager NavManager

<PageTitle>QR Code - Pulse</PageTitle>

<style>
    .qr-page-container {
        min-height: calc(100vh - 70px);
        padding: 32px 16px;
        background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
    }

    .qr-page-card {
        max-width: 900px;
        margin: 0 auto;
        background: white;
        border-radius: 12px;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.15);
        overflow: hidden;
    }

    .qr-page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .qr-page-title {
        font-size: 1.75rem;
        font-weight: 700;
    }

    .qr-page-subtitle {
        opacity: 0.9;
        margin-top: 4px;
    }

    .qr-page-content {
        padding: 32px;
    }

    .qr-page-instructions {
        background: #eff6ff;
        border-left: 4px solid #3b82f6;
        padding: 16px;
        border-radius: 4px;
        margin-bottom: 32px;
    }

    .qr-page-instructions-title {
        font-weight: 600;
        color: #1e40af;
        margin-bottom: 8px;
    }

    .qr-page-instructions-text {
        color: #0c4a6e;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .qr-page-buttons {
        display: flex;
        gap: 12px;
        margin-top: 32px;
    }

    .qr-page-button {
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .qr-page-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
        }

        .qr-page-buttons {
            flex-direction: column;
        }

        .qr-page-button {
            width: 100%;
        }
    }
</style>

<div class="qr-page-container">
    <div class="qr-page-card">
        <!-- Header -->
        <div class="qr-page-header">
            <div>
                <div class="qr-page-title">📱 Share Session</div>
                <div class="qr-page-subtitle">Students can scan or enter the code to join</div>
            </div>
            <MudIcon Icon="@Icons.Material.Filled.QrCode" Style="font-size: 3rem; opacity: 0.8;" />
        </div>

        <!-- Content -->
        <div class="qr-page-content">
            <!-- Instructions -->
            <div class="qr-page-instructions">
                <div class="qr-page-instructions-title">✓ How to Share:</div>
                <div class="qr-page-instructions-text">
                    <ol style="margin: 0; padding-left: 20px;">
                        <li>Share the QR code or session code with your students</li>
                        <li>Students can scan the QR code with their mobile device</li>
                        <li>Or they can visit Pulse and enter the session code manually</li>
                        <li>They'll be able to access and start the quiz immediately</li>
                    </ol>
                </div>
            </div>

            <!-- QR Component -->
            <SessionQRCode SessionId="@SessionId" JoinCode="@JoinCode" />

            <!-- Action Buttons -->
            <div class="qr-page-buttons">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Class="qr-page-button"
                           StartIcon="@Icons.Material.Filled.Print">
                    Print
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Class="qr-page-button"
                           @onclick="GoBack">
                    Back to Dashboard
                </MudButton>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string SessionId { get; set; } = string.Empty;

    [SupplyParameterFromQuery]
    public string JoinCode { get; set; } = string.Empty;

    private void GoBack()
    {
        NavManager.NavigateTo("/instructor");
    }
}
