@page "/join"
@using System.Net.Http.Json
@using System.Text.Json
@using MudBlazor

<PageTitle>Join Session</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-16">
    <MudPaper Class="pa-6">
        <MudText Typo="Typo.h4" GutterBottom="true">Join a Session</MudText>
        
        <MudTextField @bind-Value="JoinCode"
                      Label="Session Code"
                      Placeholder="Enter 6-character code"
                      Disabled="IsLoading"
                      Class="mb-4" />
        
        <MudButton OnClick="HandleJoinSession"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   Disabled="IsLoading || string.IsNullOrWhiteSpace(JoinCode)">
            @if (IsLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Joining...</span>
            }
            else
            {
                <span>Join Session</span>
            }
        </MudButton>

        @if (!string.IsNullOrEmpty(SessionTitle))
        {
            <MudAlert Severity="Severity.Success" Class="mt-4">
                <MudText Typo="Typo.h6">Welcome!</MudText>
                <MudText>Session: <strong>@SessionTitle</strong></MudText>
            </MudAlert>
        }

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">
                <MudText>@ErrorMessage</MudText>
            </MudAlert>
        }
    </MudPaper>
</MudContainer>

@code {
    private string JoinCode = string.Empty;
    private string SessionTitle = string.Empty;
    private string ErrorMessage = string.Empty;
    private bool IsLoading = false;

    [Inject]
    private HttpClient HttpClient { get; set; } = default!;

    private async Task HandleJoinSession()
    {
        if (string.IsNullOrWhiteSpace(JoinCode))
            return;

        IsLoading = true;
        SessionTitle = string.Empty;
        ErrorMessage = string.Empty;

        try
        {
            var response = await HttpClient.GetAsync($"/api/sessions/join/{Uri.EscapeDataString(JoinCode)}");

            if (response.IsSuccessStatusCode)
            {
                var jsonContent = await response.Content.ReadAsStringAsync();
                using var doc = JsonDocument.Parse(jsonContent);
                var root = doc.RootElement;
                if (root.TryGetProperty("title", out var titleElement))
                {
                    SessionTitle = titleElement.GetString() ?? "Session";
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                ErrorMessage = "Session not found. Please check your code.";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                ErrorMessage = "Invalid session code. Please try again.";
            }
            else
            {
                ErrorMessage = $"An error occurred (Status: {(int)response.StatusCode}). Please try again.";
            }
        }
        catch
        {
            ErrorMessage = "Unable to connect to the server. Please check your internet connection.";
        }
        finally
        {
            IsLoading = false;
        }
    }
}
